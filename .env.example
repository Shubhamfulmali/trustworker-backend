PORT=3000

# Set a strong random key here. Your Android app must send this same value
# in the "x-api-key" header for POST / PUT / DELETE requests.
# If left empty, write operations are NOT protected (fine for local testing only).
ADMIN_API_KEY=change-this-to-a-strong-secret

# OPTIONAL — only needed if you want push notifications + worker phone-login.
# Leave blank and everything else in the app still works fine.
# See README "Firebase setup" section for how to generate this.
FIREBASE_SERVICE_ACCOUNT_BASE64=
